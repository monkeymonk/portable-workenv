#!/usr/bin/env bash
set -eu

_src="${BASH_SOURCE[0]}"
while [[ -L "$_src" ]]; do
  _dir="$(cd -P "$(dirname "$_src")" && pwd)"
  _src="$(readlink "$_src")"
  [[ "$_src" != /* ]] && _src="$_dir/$_src"
done
SCRIPT_DIR="$(cd -P "$(dirname "$_src")" && pwd)"
unset _src _dir
# shellcheck source=../libexec/_workenv-lib.sh
source "$SCRIPT_DIR/../libexec/_workenv-lib.sh"

if [[ "${1:-}" == "--all" ]]; then
  names=()
  while IFS= read -r n; do
    names+=("$n")
  done < <(docker ps --filter "name=^workenv-" --format '{{.Names}}')
  if [[ ${#names[@]} -eq 0 ]]; then
    echo "workenv-stop: no workenv-* containers running"
    exit 0
  fi
  for n in "${names[@]}"; do
    echo "stopping $n"
    docker stop "$n" >/dev/null
  done
  exit 0
fi

project="${1:-$PWD}"
if [[ -d "$project" ]]; then
  project="$(cd "$project" && pwd)"
  name="$(workenv_container_name "$project")"
else
  name="workenv-${project#workenv-}"
fi

if docker ps --format '{{.Names}}' | grep -qx "$name"; then
  echo "stopping $name"
  docker stop "$name" >/dev/null
else
  echo "workenv-stop: $name is not running"
fi

#!/usr/bin/env bash
# Legacy alias: equivalent to `workenv stop`. Kept for backward compatibility;
# opt-in during install.sh.
set -euo pipefail

_src="${BASH_SOURCE[0]}"
while [[ -L "$_src" ]]; do
  _dir="$(cd -P "$(dirname "$_src")" && pwd)"
  _src="$(readlink "$_src")"
  [[ "$_src" != /* ]] && _src="$_dir/$_src"
done
SCRIPT_DIR="$(cd -P "$(dirname "$_src")" && pwd)"
unset _src _dir

exec "$SCRIPT_DIR/workenv" stop "$@"
